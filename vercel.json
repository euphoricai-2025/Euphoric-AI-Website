{
  "redirects": [
    {
      "source": "/signup",
      "destination": "https://dashboard.euphoricai.io/signup",
      "permanent": false
    },
    {
      "source": "/signin",
      "destination": "https://dashboard.euphoricai.io/",
      "permanent": false
    },
    {
      "source": "/trial",
      "destination": "https://dashboard.euphoricai.io/free-trial",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}